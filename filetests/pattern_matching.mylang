function printf(fmt: *i8, ...);

type Expr enum {
    Int(i32),
    String(*i8),
}

function Print(e: Expr) {
    if let Int(i) = e {
        printf("%d\n", i);
    }
    if let String(s) = e {
        printf("%s\n", s);
    }
}

function main() -> i32 {
    // check: 1
    let e = Expr.Int(1);
    Print(e);
    // nextln: hello world
    e = Expr.String("hello world");
    Print(e);

    return 0;
}
