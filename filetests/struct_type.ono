import libc;

type String = struct {
  ptr: *i8,
};

function make_string(ptr: *i8) -> String {
  return { ptr: ptr };
}

function cmp(x: String, y: String) -> i32 {
  return libc.strcmp(x.ptr, y.ptr);
}

function len(s: String) -> i64 {
  return libc.strlen(s.ptr);
}

function main() -> i32 {

  // check: abcdefg
  // nextln: 7
  let s: String = make_string("abcdefg");
  libc.printf("%s\n", s.ptr);
  libc.printf("%d\n", len(s));

  // nextln: 0
  libc.printf("%d\n", cmp(s, s));

  return 0;
}
