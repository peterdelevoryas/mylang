fn printf(fmt: *i8, ...);

type Vec3 struct {
    x: f32,
    y: f32,
    z: f32,
}

fn Dot(x: Vec3, y: Vec3) -> f32 {
    return x.x * y.x + x.y * y.y + x.z * y.z;
}

fn main() -> i32 {
    let x: Vec3 = { x: 1.0, y: 2.0, z: 3.0, };
    let y: Vec3 = { x: 7.0, y: 8.0, z: 9.0, };
    let p = Dot(x, y);
    // check: 50.000000
    printf("%f\n", p as f64);
    return 0;
}
