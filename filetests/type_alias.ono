import libc;

type Int = i32;
type Long = i64;
type Char = i8;

function main(argc: Int, argv: **Char) -> Int {
  let file: *libc.FILE = libc.fopen(argv[0], "r");
  if file != null {
    libc.fseek(file, 0, 2);
    let size: Long = libc.ftell(file);
    if size < 0 {
      libc.fclose(file);
      return 1;
    }
    libc.fclose(file);
  }
  if argc < 2 {
    libc.printf("not enough arguments\n");
  }
  return 0;
}
