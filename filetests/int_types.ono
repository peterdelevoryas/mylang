import libc;

function main() -> i32 {

  // check: 127
  let x: i8 = 127;
  libc.printf("%hhd\n", x);

  // nextln: 32767
  let x: i16 = 32767;
  libc.printf("%hd\n", x);

  // nextln: 2147483647
  let x: i32 = 2147483647;
  libc.printf("%d\n", x);

  // nextln: 9223372036854775807
  let x: i64 = 9223372036854775807;
  libc.printf("%ld\n", x);

  return 0;
}
