import libc;

type Expr = enum {
  Int(i32),
  String(*i8),
};

function print(e: Expr) {
  if let Int(i) = e {
    libc.printf("%d\n", i);
  }
  if let String(s) = e {
    libc.printf("%s\n", s);
  }
}

function main() -> i32 {
  // check: 1
  let e = Expr.Int(1);
  print(e);
  // nextln: hello world
  e = Expr.String("hello world");
  print(e);

  return 0;
}
